    <packagedElement xmi:type="uml:Stereotype" xmi:id="1ccbef10-c742-42d8-9cd8-ab06d9e6f53a" name="derivedPropertySpecification">
      <eAnnotations xmi:id="_kxqOiC6dEfGkQvt4yBF-gg" source="MagicDraw">
        <details xmi:id="_kxqOiS6dEfGkQvt4yBF-gg" key="md_id" value="1ccbef10-c742-42d8-9cd8-ab06d9e6f53a"/>
      </eAnnotations>
      <ownedComment xmi:id="549af216-1572-4300-9a6a-bf352757b9d6" body="Stereotype to define derived property. Property owned by DSL customization class should be stereotyped with derivedPropertySpecification in order to be included in MagicDraw as derived property. derivedPropertySpecification element has one or many expression to calculate derived property in different languages. Derived properties result is union of results of defined expressions." annotatedElement="1ccbef10-c742-42d8-9cd8-ab06d9e6f53a">
        <eAnnotations xmi:id="_kxqOii6dEfGkQvt4yBF-gg" source="MagicDraw">
          <details xmi:id="_kxqOiy6dEfGkQvt4yBF-gg" key="md_id" value="549af216-1572-4300-9a6a-bf352757b9d6"/>
        </eAnnotations>
      </ownedComment>
      <ownedAttribute xmi:id="c4177fd7-4e13-4b2d-a2ac-c634946fc5c0" name="expression" visibility="private" isOrdered="true">
        <eAnnotations xmi:id="_kxqOjC6dEfGkQvt4yBF-gg" source="MagicDraw">
          <details xmi:id="_kxqOjS6dEfGkQvt4yBF-gg" key="md_id" value="c4177fd7-4e13-4b2d-a2ac-c634946fc5c0"/>
        </eAnnotations>
        <ownedComment xmi:id="0e533eb5-0cbd-417a-a96c-540bbebf22ae" body="List of different types of criteria how to gather dependent elements: Simple (UML Relation, Property or Tag); Meta Chain, OCL and Binary. If several criterion are defined results is union of all of them.&#xA;&#xA;Expression can be used in Derived Property Specification, Dependency Matrix, Dependency Map." annotatedElement="c4177fd7-4e13-4b2d-a2ac-c634946fc5c0">
          <eAnnotations xmi:id="_kxqOkC6dEfGkQvt4yBF-gg" source="MagicDraw">
