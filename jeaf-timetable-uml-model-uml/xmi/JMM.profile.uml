    <packagedElement xmi:type="uml:Stereotype" xmi:id="8224074e-2225-4da5-9899-4caa28817b71" name="BreakingChange" clientDependency="462ae970-3a3b-46c7-b5f2-9a75d1ad5c9f">
      <ownedComment xmi:id="6672b212-826f-4c28-9d4b-fe4d1b0f3e6d" body="Stereotype `«BreakingChange»` can be used to mark model elements that are a breaking change compared to a previous version from a client / consumer perspective.&#xA;&#xA;This is especially useful when you are working with semantic versioning approach. Using this stereotype you can then mark elements that break backward compatibility.&#xA;&#xA;Example: a new request property is introduced and after a transition phase it will be mandatory.&#xA;&#xA;JEAF Generator supports a so called breaking changes report that lists all the breaking changes.&#xA; " annotatedElement="8224074e-2225-4da5-9899-4caa28817b71"/>
      <ownedAttribute xmi:id="6806ad30-7846-41ca-96aa-bebbb051712e" name="description" visibility="private">
        <ownedComment xmi:id="ad145d3f-2012-4b90-a079-9339f64c61cb" body="Description of an upcoming breaking change." annotatedElement="6806ad30-7846-41ca-96aa-bebbb051712e"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="7c12e947-21d8-4bce-8d1f-43249b2c5592" name="since" visibility="private">
        <ownedComment xmi:id="732f78be-a21f-4476-b85a-9c3cf0bfa574" body="Information since when a breaking change was announced for a model element e.g. a concrete version or date." annotatedElement="7c12e947-21d8-4bce-8d1f-43249b2c5592"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="a661e63c-3b81-4afc-9020-5e8f60eacf86" name="activeWith" visibility="private">
        <ownedComment xmi:id="cd287068-965e-42f5-aa15-3c78fa0c70ca" body="Version when a breaking change becomes active. &#xA;&#xA;**Example:**&#xA;- A new parameter is introduced for a request. To not immediately break the API at first the parameter is optional. Using this field it can be defined when the parameter will be mandatory." annotatedElement="a661e63c-3b81-4afc-9020-5e8f60eacf86"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="003a4031-2223-427a-a615-7dc8d5650faa" name="base_NamedElement" visibility="private" association="89aadee8-3011-4d97-a7c7-2710b8da98e4">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#NamedElement"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="09d91cec-baa5-403f-ac4a-00e9c2e9e2a0" name="plannedChangeType" visibility="private" type="c2543fc0-c46c-4a01-bfaa-e76377170eda">
        <ownedComment xmi:id="65322532-e0fe-4329-93c1-eeb9a5e0e948" body="Type of the planned change." annotatedElement="09d91cec-baa5-403f-ac4a-00e9c2e9e2a0"/>
        <defaultValue xmi:type="uml:InstanceValue" xmi:id="425c87f4-a727-4153-a3f4-53f074d0fcb9" name="" instance="2ba57560-259f-4963-9260-9749be7e7067"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="6583bcff-97b9-4d92-a217-e56f01b508f6" name="JEAFDeprecated">
      <ownedComment xmi:id="1d76300a-54d5-48bc-8282-440b8368c87f" body="Deprecations are markers that indicate that a specific model element should not be used any longer. To do so, you just have to apply the stereotype `«JEAFDeprecated»` to the model element. This can be anything from a whole class or interface to an parameter of an operation." annotatedElement="6583bcff-97b9-4d92-a217-e56f01b508f6"/>
      <ownedAttribute xmi:id="1a54c1b1-911f-4115-a36e-4797d9534c80" name="description">
        <ownedComment xmi:id="46e094f3-e4dc-4b4c-a66d-b97ca69416cb" body="Explanation which the element is deprecated and what should be done as an alternative." annotatedElement="1a54c1b1-911f-4115-a36e-4797d9534c80"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="f876a602-486a-4fd9-ac9e-20b7805a3910" name="since" visibility="private">
        <ownedComment xmi:id="e6daeeef-27f9-4ac0-9b13-8f3b56e119bf" body="Information since when a model element is deprecated e.g. a concrete version or date." annotatedElement="f876a602-486a-4fd9-ac9e-20b7805a3910"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="3ddb5674-60ab-4570-8743-60dfcff490a0" name="removedWith" visibility="private">
        <ownedComment xmi:id="12667419-8630-4b65-90c8-713a0bb068fa" body="Information when the deprecated element will no longer be available e.g. a version or date." annotatedElement="3ddb5674-60ab-4570-8743-60dfcff490a0"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="ef0f458f-3df1-4270-8cc5-c5853718db4e" name="generateBackwardCompatibility" visibility="private">
        <ownedComment xmi:id="f3c94a33-7f26-47bd-b338-e863af1154a2" body="JEAF Generator supports developers ensuring backward compatibility of deprecations on Java and JSON level. &#xA;&#xA;This mechanism has to be activated for each deprecation separately using this flag. In addition the name of the successor property has to be provided using tag `successorName`." annotatedElement="ef0f458f-3df1-4270-8cc5-c5853718db4e"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="6c55bdd5-9d92-40d3-8dd6-e2796c38a823" name="successorName" visibility="private">
        <ownedComment xmi:id="6ec57e0e-a21b-4da5-9999-3a6bae428c51" body="Name of the property that should be used instead of this one. Setting this value is only required in case that you want backward compatibility to be generated." annotatedElement="6c55bdd5-9d92-40d3-8dd6-e2796c38a823"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="c31343b6-a70d-4a3b-a905-b22d45c585f5" name="base_Element" visibility="private" association="cb75ec9a-8992-488b-90cb-8470a195233e">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Element"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="b3250f9e-81b5-446f-9055-760cf9778d32" name="ReleaseUnit">
      <ownedComment xmi:id="5d856bac-18ee-421a-b8f8-130226ffa111" body="JEAF Generator allows release note information to be defined directly in the UML model using the stereotypes: `«ReleaseUnit»`, `«Release»`, `«ChangeDescription»` and `«ReleaseNotesEntry»`.&#xA;&#xA;Stereotype `«ReleaseUnit»` marks a package that contains release information for an artifact." annotatedElement="b3250f9e-81b5-446f-9055-760cf9778d32"/>
      <ownedAttribute xmi:id="70d06285-619f-47fd-bb4d-35090e8e8c2e" name="releaseUnitName" visibility="private">
        <ownedComment xmi:id="64803684-da8e-4e26-8bcd-a08d1b25161b" body="Tagged value for the name of the release unit." annotatedElement="70d06285-619f-47fd-bb4d-35090e8e8c2e"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="8c979216-0d9f-488e-a1bc-796de574daf8" name="base_Package" visibility="private" association="ba3f9481-26ff-41e5-b548-ab5804036421">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Package"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="5d17ad58-8b8c-4519-8336-39d4a09f5fc4" name="issueTrackingURL" visibility="private">
        <ownedComment xmi:id="ac3c8d09-7de1-46c9-b9a0-18c567ac9601" body="Base URL of the issue tracking system. This information will be used to provide links to issues in release notes.&#xA;&#xA;It is also possible to provide that information on domain and on global level." annotatedElement="5d17ad58-8b8c-4519-8336-39d4a09f5fc4"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="fc060ae4-c798-48c8-a99d-3dc733fa12c9" name="issueDisplayNamePrefix" visibility="private">
        <ownedComment xmi:id="91ca1e06-875a-41f9-a6de-7516719c6745" body="Optional name prefix for an issue. This prefix will only be used as display info for the ID of an issue." annotatedElement="fc060ae4-c798-48c8-a99d-3dc733fa12c9"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="fe217da7-1916-499c-8b49-1f06f79529e4" name="groupId" visibility="private">
        <ownedComment xmi:id="8c92bbc4-6402-4b78-90fb-1e6c9956473c" body="Maven Group ID of a release unit. &#xA;&#xA;This information only is required if Maven project structures are not defined within the UML model." annotatedElement="fe217da7-1916-499c-8b49-1f06f79529e4"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="b5fd30f6-6676-432a-a5f3-d71e98b61586" name="artifactId" visibility="private">
        <ownedComment xmi:id="5c220d2d-2e21-4360-8b46-86493a42c819" body="Maven Artifact ID of a release unit. &#xA;&#xA;This information only is required if Maven project structures are not defined within the UML model." annotatedElement="b5fd30f6-6676-432a-a5f3-d71e98b61586"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
