    <packagedElement xmi:type="uml:Extension" xmi:id="85667786-1144-42e4-87ab-e25c601c11be" name="" memberEnd="0267c5de-2c13-4cef-83b4-a5006ebb24da 467c49f8-9b03-4cb7-ac9a-68cdcb6f3132" navigableOwnedEnd="0267c5de-2c13-4cef-83b4-a5006ebb24da">
