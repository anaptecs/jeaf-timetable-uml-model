    <packagedElement xmi:type="uml:Stereotype" xmi:id="abe04c52-7aaa-47da-91ae-7ffebb04cefa" name="SoftLink" clientDependency="da72e23e-dc6b-4c9b-b61d-4f3a71406b48">
      <ownedComment xmi:id="f8affba1-ad84-4858-b9dc-233978958517" body="So called soft links are a mechanism to decouple objects within your application. From a model perspective there is just a directed association between 2 classes of your model. But as the association end is marked as soft link using stereotype `«SoftLink»` in the generated code there will be just a proxy type e.g. a String representing the ID of the object and not a direct reference to the class." annotatedElement="abe04c52-7aaa-47da-91ae-7ffebb04cefa"/>
      <ownedAttribute xmi:id="0f2e52f5-8d6c-4d92-b643-a0401cfd3f5c" name="base_Property" visibility="private" association="9883546b-fcea-46da-982b-c4487ac7b7dd">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Property"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="bb4382b1-7272-49c3-9315-7bf54e4411b1" name="softLinkType" visibility="private" type="fc902063-3da2-41e0-b4a1-3797cfee9fc2">
        <ownedComment xmi:id="9bcd6122-839d-4b41-ad9f-0047154dd847" body="JEAF Generator supports the following types for soft links: `String`, `long`, `Long` and `CustomGenericType`.&#xA;&#xA;In case of `CustomGenericType` the actual type has to be defined as configuration parameter for JEAF Generator in the Maven Configuration. This way you can define your own types." annotatedElement="bb4382b1-7272-49c3-9315-7bf54e4411b1"/>
        <defaultValue xmi:type="uml:InstanceValue" xmi:id="d744f704-041e-4d28-8a72-e55a3364328a" name="" instance="62e130df-32a4-43c8-907a-b8ffee00c69c"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="9883546b-fcea-46da-982b-c4487ac7b7dd" name="" memberEnd="0b716091-5fe7-4ce5-9274-8fffb4a8a568 0f2e52f5-8d6c-4d92-b643-a0401cfd3f5c" navigableOwnedEnd="0b716091-5fe7-4ce5-9274-8fffb4a8a568">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="0b716091-5fe7-4ce5-9274-8fffb4a8a568" name="extension_SoftLink" visibility="private" type="abe04c52-7aaa-47da-91ae-7ffebb04cefa" aggregation="composite" association="9883546b-fcea-46da-982b-c4487ac7b7dd">
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="068db054-5b0e-4c58-a4cc-ff6b13b9b5a5" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="2da841a5-dac3-4046-a8d5-b34e1611e340" name=""/>
      </ownedEnd>
    </packagedElement>
