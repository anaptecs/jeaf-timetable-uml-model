    <packagedElement xmi:type="uml:Stereotype" xmi:id="fba0640f-c5f3-4c7a-b4bc-0443b8ee0953" name="TemplateBindingMultiplicity">
      <ownedComment xmi:id="85dfeaa6-9f59-42f6-8a02-f2cda1c02218" body="JEAF Generator also supports usage of generic types (called template bindings in UML). &#xA;&#xA;By default however, it is not possible to define a multiplicity on the template binding. To do so this stereotype is required." annotatedElement="fba0640f-c5f3-4c7a-b4bc-0443b8ee0953"/>
      <ownedAttribute xmi:id="5c397083-b216-476f-8a90-b4a8a90eb379" name="multivalued" visibility="private">
        <ownedComment xmi:id="6d433d31-4e74-44ac-a05e-1688de0ec3b6" body="Attribute is used to mark a template binding as multivalued. By default it is not." annotatedElement="5c397083-b216-476f-8a90-b4a8a90eb379"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="29b56968-1c68-4f44-8ef0-3cc5304a0ba8" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="a0108830-a0a4-4330-9364-c42022dd1e20" name="ordered" visibility="private">
        <ownedComment xmi:id="74edb784-e833-4414-bfe5-7449579cea09" body="Using attributes `ordered` and `unique` the Java collection type can be controlled like for any other multivalued property.&#xA;&#xA;For further details please check: [Java Collection Types](/developer-guide/general-behavior/#usage-of-java-collection-types)" annotatedElement="a0108830-a0a4-4330-9364-c42022dd1e20"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="2b3bfaff-a259-46b4-9975-b95d5df68073" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="d26f3e14-fecb-4ac2-9a6a-52a5f5be490a" name="unique" visibility="private">
        <ownedComment xmi:id="2dc555ee-6c1f-41bd-aed3-97612b7beaf9" body="Using attributes `ordered` and `unique` the Java collection type can be controlled like for any other multivalued property.&#xA;&#xA;For further details please check: [Java Collection Types](/developer-guide/general-behavior/#usage-of-java-collection-types)" annotatedElement="d26f3e14-fecb-4ac2-9a6a-52a5f5be490a"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="8f1ca61b-17b0-4aad-9988-3a7bb66f41bf" name="" value="true"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="93f24cce-9a22-4501-82ee-4ca7d706dbb2" name="base_TemplateBinding" visibility="private" association="cf7fac56-f4b4-43b3-b9f0-74ce9cd3f2c4">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#TemplateBinding"/>
      </ownedAttribute>
    </packagedElement>
