    <packagedElement xmi:type="uml:Dependency" xmi:id="14be669c-d20f-4b49-97cf-be77ce4456c1" name="" supplier="a72b2444-b8dc-4507-8341-496b0848db7a" client="bb0d9bc6-8de2-4d9a-ba57-87eab6f2c37f"/>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="536b0817-10b9-4016-ada5-95254c9cea34" name="OpenAPI3Specification">
      <ownedComment xmi:id="235c3535-c317-406e-b31a-e04992f0e62f" body="Stereotype `«OpenAPI3Specification»` can be used to mark a component as OpenAPI 3 specification. This element represents the specification document that will be generated by JEAF Generator." annotatedElement="536b0817-10b9-4016-ada5-95254c9cea34"/>
      <ownedComment xmi:id="5c20a5a6-43f4-4578-b8c8-325583328947" body="For further information please refer to:&#xA;- [How to publish REST Services as OpenAPI 3 specification](/uml-modeling-guide/how-tos/how-to-model-open-api)&#xA;- [Generating OpenAPI Specification](/developer-guide/generating-open-api-spec)" annotatedElement="536b0817-10b9-4016-ada5-95254c9cea34"/>
      <ownedAttribute xmi:id="cd8f6440-9b27-4370-beb7-625f1a1e9492" name="resourceName" visibility="private">
        <ownedComment xmi:id="b801563e-4a38-4aaa-b32e-bed7b3b60d5f" body="Name of the file that will be generated as OpenAPI specification file. By default it will be named as `openapi.yml`." annotatedElement="cd8f6440-9b27-4370-beb7-625f1a1e9492"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <defaultValue xmi:type="uml:LiteralString" xmi:id="a16adfa7-a9f2-471a-8fc6-5ec2b18d71ac" name="" value="openapi.yaml"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="e0573d79-60dd-4877-bd30-418e838d47e4" name="apiVersion" visibility="private">
        <ownedComment xmi:id="ecb848cc-537c-4a91-984e-ad4ff5d9a93f" body="Version of the API that is represented by this OpenAPI specification. We strongly recommend to version you API according to the rules of [Semantic Versioning](https://semver.org)." annotatedElement="e0573d79-60dd-4877-bd30-418e838d47e4"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="3cd5c585-4481-421c-b3a0-222cf94cb169" name="base_Component" visibility="private" association="3819cf9e-648e-4328-ab1a-0e6366954495">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Component"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="089539de-b38c-40b8-86c1-f130df7d2e1a" name="contactName" visibility="private">
        <ownedComment xmi:id="cf7bd389-0e17-4013-9ec8-2c68f5385dc5" body="Name of the team or person that will be mentioned in your OpenAPI specification as contact." annotatedElement="089539de-b38c-40b8-86c1-f130df7d2e1a"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="c56cff09-420b-4554-a405-f63f0e62a9d6" name="contactURL" visibility="private">
        <ownedComment xmi:id="80913963-c5c2-45ec-9cf5-b42b74148d46" body="URL of the contact for your OpenAPI specification." annotatedElement="c56cff09-420b-4554-a405-f63f0e62a9d6"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="ec29c913-ffb0-45a4-87d4-b7cbf414393a" name="contactEmail" visibility="private">
        <ownedComment xmi:id="e589ab60-c84c-4d6e-b743-319ec467bf79" body="Email of the contact that is mentioned in your OpenAPI specification." annotatedElement="ec29c913-ffb0-45a4-87d4-b7cbf414393a"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="e822a184-9c07-4d86-8b00-a7a4610ff435" name="licenseName" visibility="private">
        <ownedComment xmi:id="5ab9e9d9-1339-4a2c-8239-19ee5586c2f4" body="Name of the license under which your OpenAPI specification is published e.g. `Apache 2.0`." annotatedElement="e822a184-9c07-4d86-8b00-a7a4610ff435"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="2c2430d9-4b1b-41ed-86df-2487992f55a3" name="licenseURL" visibility="private">
        <ownedComment xmi:id="a4ba790c-5fe5-4a58-9f7b-3f37079c1f64" body="URL under which the used license is available." annotatedElement="2c2430d9-4b1b-41ed-86df-2487992f55a3"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="54981e81-ae5e-48c7-91a8-1a4aef14df1e" name="termsOfUseURL" visibility="private">
        <ownedComment xmi:id="e0227766-8ae2-4517-8095-e3b79d5a835d" body="URL under which the terms of use are published." annotatedElement="54981e81-ae5e-48c7-91a8-1a4aef14df1e"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="004bb222-57ea-4964-8dc9-3c8a5137fac1" name="securityOptional" visibility="private">
        <ownedComment xmi:id="25fb897f-5137-4684-a71b-12f18fd3aaff" body="Tagged value can be used to define that the security section of the OpenAPI specification will not be provided." annotatedElement="004bb222-57ea-4964-8dc9-3c8a5137fac1"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="f8e5dcca-f5cb-4024-96cc-690f5cfd18a8" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="ce5e1046-c274-4a63-b93b-8c76206cfc6b" name="explicityTypeOrdering" visibility="private">
        <ownedComment xmi:id="339d339d-872f-47d5-ad8e-3cb91cb06fdf" body="By default types are ordered in an alphabetic order. However, JEAF Generator also supports to define an explicit type ordering in OpenAPI specifications. &#xA;&#xA;This can be enabled using this tagged value. In addition stereotype «Ordered» has to be applied on the elements of the OpenAPI Types that belong to the OpenAPI specification." annotatedElement="ce5e1046-c274-4a63-b93b-8c76206cfc6b"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="15a58cac-cb7e-4555-b617-a766a763dc9e" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="a01388f9-de9a-4583-b9ec-dd2722f409b4" name="explicitPathOrdering" visibility="private">
        <ownedComment xmi:id="6f69dd8b-43df-4c32-9b0b-7ce855abb3f9" body="As for types it is also to define an explicit order for paths. &#xA;&#xA;This can be enabled using tagged value. In addition stereotype «Ordered» has to be applied on the REST operations that belong to the OpenAPI specification." annotatedElement="a01388f9-de9a-4583-b9ec-dd2722f409b4"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="7f01cea9-100e-4b8b-b762-cabe28eb8e31" name=""/>
      </ownedAttribute>
