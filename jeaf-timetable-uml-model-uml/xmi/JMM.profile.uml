    <packagedElement xmi:type="uml:Stereotype" xmi:id="20ec9a6a-a50a-42ee-80c7-17cfe18a9e91" name="DefaultComment" clientDependency="f423a468-51ee-48cd-a41f-d9ea93b48792">
      <ownedComment xmi:id="a51b3508-bafe-4680-a609-ef68190ef446" body="Stereotype `«DefaultComment»` can be used to mark a comment of a type as its default comment in case that the type is used as parameter and no explicit comment is provided for a parameter." annotatedElement="20ec9a6a-a50a-42ee-80c7-17cfe18a9e91"/>
      <ownedAttribute xmi:id="65aaa527-1f2f-42e9-a84b-3564df8794f6" name="base_Comment" visibility="private" association="9c4a0f08-5c74-4eb2-bf5c-b95675762f9a">
