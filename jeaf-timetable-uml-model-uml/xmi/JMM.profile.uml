      <packagedElement xmi:type="uml:Dependency" xmi:id="b58d5586-0b95-446b-a911-d4cb41e42575" name="" supplier="bdf59cab-836a-4216-8032-96395e18a440" client="dba37e3a-d310-4806-99c6-023edd567542"/>
