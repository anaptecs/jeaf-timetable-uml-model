      </ownedAttribute>
      <ownedAttribute xmi:id="fbb4760f-14f1-4d0d-8af1-600ef0e4e392" name="applicableElementTypes" visibility="private" type="a52fd13e-6a54-4447-bd7b-c97b11a06378">
        <ownedComment xmi:id="e3469bce-b90c-4aa6-bc41-b7e9edad475b" body="Tagged value defines for which model element types the default comment should be applied." annotatedElement="fbb4760f-14f1-4d0d-8af1-600ef0e4e392"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="f118c069-82f6-4139-bb4d-06bb99a735d2" name="" value="*"/>
