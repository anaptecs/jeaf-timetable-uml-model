      <ownedLiteral xmi:id="7bbe91a8-d303-4c9b-aaec-5c2e4b0c82b3" name="THROW_NOT_YET_IMPLMENTED_EXCEPTION" classifier="704f933a-5ff1-45a4-8e75-bc06d122be57"/>
