    <packagedElement xmi:type="uml:Stereotype" xmi:id="ce0c25dc-f145-4481-9c2c-2e8bf365c18b" name="RESTOperation" clientDependency="b756b5a7-3ee4-4c67-9b29-a943f84a7609 ec3179ee-c823-4906-b633-be68d257b0d0">
      <ownedComment xmi:id="bafc6fa1-546c-4a90-9d97-827b54a5d05f" body="Stereotype `«RESTOperation»` is used to mark that an operation of a service should also be accessible via REST. &#xA;&#xA;Please be aware that the stereotype can only be applied on an operation of an interface that is marked as «JEAFService»." annotatedElement="ce0c25dc-f145-4481-9c2c-2e8bf365c18b"/>
      <ownedComment xmi:id="c522b624-9fde-4a11-9f0e-4a13789668f8" body="For further information please refer to:&#xA;- [How to model REST Services](/uml-modeling-guide/how-tos/how-to-model-rest-service-apis)&#xA;- [Generating Code for REST Services](/developer-guide/code-for-jeaf-services)" annotatedElement="ce0c25dc-f145-4481-9c2c-2e8bf365c18b"/>
      <ownedAttribute xmi:id="a0d6272f-f496-48f0-b149-540020ed952b" name="path" visibility="private">
        <ownedComment xmi:id="9cf785c1-0887-4423-b447-a61f5536a7a7" body="Path under which the REST resource should be available. The attribute is optional in case that a path is already defined for the REST resource." annotatedElement="a0d6272f-f496-48f0-b149-540020ed952b"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="4abfb8f8-b8ca-4f3f-99a7-dcbc215368d3" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="9f4d38dd-d7cb-4d66-a5d9-a92a3d96092e" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="e93f96f2-6494-4228-99d7-e6d411dcd40d" name="httpMethods" visibility="private" type="7af5ca1b-9245-41a4-9d19-04e530ee75a9">
        <ownedComment xmi:id="21fcd229-4b4b-4428-a0f3-cb3b3411ec50" body="HTTP methods that are used to request the operation. At least one method must be defined." annotatedElement="e93f96f2-6494-4228-99d7-e6d411dcd40d"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="6cdd3bba-7176-4569-a37e-c5d28d1a5936" name="" value="*"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="18389a5f-27d4-4b21-9c0c-3c6595449c1c" name="" value="1"/>
