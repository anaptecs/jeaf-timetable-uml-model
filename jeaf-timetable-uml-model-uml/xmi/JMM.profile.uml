    <packagedElement xmi:type="uml:Stereotype" xmi:id="8285fc6a-9b52-4d4b-9d5a-d1978c4f69d4" name="OpenAPISecurityScheme" clientDependency="40706292-a644-4990-8a10-b2adaabd7a33 4df29ade-8fd1-4320-b7d3-4378d9ff6054">
      <ownedComment xmi:id="93d43c84-70d5-408c-a10e-e1ab6434710c" body="Stereotype `«OpenAPISecurityScheme»` can be used to define the authentication mechanism for servers that are defined in the OpenAPI specification." annotatedElement="8285fc6a-9b52-4d4b-9d5a-d1978c4f69d4"/>
      <ownedAttribute xmi:id="aed2113b-aeb0-4043-ad82-51c218edcfc7" name="base_Component" visibility="private" association="a1ddb632-deec-417a-92a3-ab6ff444b110">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Component"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="a0e354e3-9f84-42a9-8718-8a95dc8ee9e0" name="type" visibility="private" type="bf8446db-16fb-4bd6-8754-859651d6812e">
        <ownedComment xmi:id="663e85cf-3352-4fa0-a80f-2599c754edf5" body="Type of the security scheme.&#xA;&#xA;Possible values are: `apiKey`, `http`, `oauth2`, `openIdConnect`" annotatedElement="a0e354e3-9f84-42a9-8718-8a95dc8ee9e0"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="19123ba7-0db7-42e7-9de0-9aab2105dff7" name="apiKeyName" visibility="private">
        <ownedComment xmi:id="d6b83ea4-b0f7-4a03-9e05-e03c4b3003d8" body="Name of the api key in case that security scheme type `apiKey` is used." annotatedElement="19123ba7-0db7-42e7-9de0-9aab2105dff7"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="55331e39-66b7-4d8c-808a-b7855244b207" name="apiKeyLocation" visibility="private" type="6046b504-61c5-413e-ad45-f9fcf2c0cdfc">
        <ownedComment xmi:id="db5d5b3a-e102-4d74-ac34-685a3d86fe2c" body="Name of the api key location in case that security scheme type `apiKey` is used. API keys can be provided as query, header or cookie param." annotatedElement="55331e39-66b7-4d8c-808a-b7855244b207"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="1dd59a56-02b8-4aa3-8c92-21639e800609" name="httpAuthorizationScheme" visibility="private">
        <ownedComment xmi:id="500ceb5a-eea7-4908-a1bd-8788216db192" body="The name of the HTTP Authorization scheme to be used in the Authorization header as defined in [RFC7235](https://httpwg.org/specs/rfc7235.html)." annotatedElement="1dd59a56-02b8-4aa3-8c92-21639e800609"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="df95c5ee-a155-4922-9583-572a8cfc0905" name="httpBearerFormat" visibility="private">
        <ownedComment xmi:id="9f9557fd-b2b4-48c2-ab22-a9a742990a1a" body="A hint to the client to identify how the bearer token is formatted. Bearer tokens are usually generated by an authorization server, so this information is primarily for documentation purposes." annotatedElement="df95c5ee-a155-4922-9583-572a8cfc0905"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="923ed153-8f1b-4329-8858-88beccac3629" name="openIdConnectUrl" visibility="private">
        <ownedComment xmi:id="a5ff802f-ea3a-464f-ba45-70bcd3470774" body="OpenId Connect URL to discover OAuth2 configuration values. This must be in the form of a URL. The OpenID Connect standard requires the use of TLS." annotatedElement="923ed153-8f1b-4329-8858-88beccac3629"/>
