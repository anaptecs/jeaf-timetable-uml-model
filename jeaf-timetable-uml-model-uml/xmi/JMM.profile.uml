    <packagedElement xmi:type="uml:Stereotype" xmi:id="557eac38-9bc5-4618-9d4b-993e6dca82d1" name="PathParam">
      <ownedComment xmi:id="06b7d99e-239c-4205-9e49-7f1eef38971b" body="Stereotype `«PathParam»` is used to mark that a parameter of an REST operation that it’s value should be taken from the request path. Please be aware that the stereotype can only be applied on an operation of an interface that is marked as `«RESTResource»` and the operation is marked as `«RESTOperation»`." annotatedElement="557eac38-9bc5-4618-9d4b-993e6dca82d1"/>
      <ownedComment xmi:id="49141745-d060-456a-bd8a-483e0635fc4b" body="For further information please refer to:&#xA;- [«REST Resource»](/uml-modeling-guide/jmm/RESTResource)&#xA;- [«REST Operation»](/uml-modeling-guide/jmm/RESTOperation)&#xA;- [How to model REST Services](/uml-modeling-guide/how-tos/how-to-model-rest-service-apis)&#xA;- [Generating Code for REST Services](/developer-guide/code-for-jeaf-services/)" annotatedElement="557eac38-9bc5-4618-9d4b-993e6dca82d1"/>
      <ownedAttribute xmi:id="b60ae5c5-4829-4bb6-ac38-440d10244b1b" name="base_Parameter" visibility="private" association="da651cf8-dd05-440b-9519-74344c81bf1b">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Parameter"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="9e1b05d4-abec-4bf5-8b1d-863a83f210b8" name="value" visibility="private">
        <ownedComment xmi:id="1f98d209-e326-4828-8a1b-38416857ee18" body="Name of the parameter as it is defined in the operations path e.g. id in path `/doSomething/{id}`.&#xA;&#xA;If no name is defined then the name of the property / parameter will also be used for the header field." annotatedElement="9e1b05d4-abec-4bf5-8b1d-863a83f210b8"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="102e016a-9b6b-475c-98fc-3539b45c5a11" name="base_Property" visibility="private" association="e704cc8b-9a6b-4ab8-a213-2c0ebcbf6b62">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Property"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="da651cf8-dd05-440b-9519-74344c81bf1b" name="" memberEnd="3e08b28a-6979-4a07-8933-6c03d1213bec b60ae5c5-4829-4bb6-ac38-440d10244b1b" navigableOwnedEnd="3e08b28a-6979-4a07-8933-6c03d1213bec">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="3e08b28a-6979-4a07-8933-6c03d1213bec" name="extension_PathParam" visibility="private" type="557eac38-9bc5-4618-9d4b-993e6dca82d1" aggregation="composite" association="da651cf8-dd05-440b-9519-74344c81bf1b">
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="d5edc79c-c284-448b-8e9a-3763103fcb6d" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="30c15bc4-14d0-42b1-aede-2401f174b0fb" name=""/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="111bca92-ca14-4a61-b047-1f758f7b5101" name="HeaderParam">
      <ownedComment xmi:id="6bc93091-0990-400d-8b2d-c8913367f7f5" body="Stereotype `«HeaderParam»` is used to mark that a parameter of a REST operation should be taken from the http header. Please be aware that the stereotype can only be applied on an operation of an interface that is marked as `«RESTResource»` and the operation is marked as `«RESTOperation»`." annotatedElement="111bca92-ca14-4a61-b047-1f758f7b5101"/>
      <ownedComment xmi:id="e7d6a80e-9f61-46fd-aae9-25a37b1dfbda" body="For further information please refer to: &#xA;- [`«REST Resource»`](/uml-modeling-guide/jmm/RESTResource) &#xA;- [`«REST Operation»`](/uml-modeling-guide/jmm/RESTOperation) &#xA;- [How to model REST Services](/uml-modeling-guide/how-tos/how-to-model-rest-service-apis) &#xA;- [Generating Code for REST Services](/developer-guide/code-for-jeaf-services)" annotatedElement="111bca92-ca14-4a61-b047-1f758f7b5101"/>
      <ownedAttribute xmi:id="64dc445d-d455-40ea-b3e9-3274679692fb" name="base_Parameter" visibility="private" association="564c5af0-c875-4ed8-993f-73de430d8600">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Parameter"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="6cd3c6db-741f-41c9-9884-b8dbc5d1caf1" name="value" visibility="private">
        <ownedComment xmi:id="8cc7fd33-84d2-43b6-8383-9810f7fa8467" body="Name of the http header field from which the parameter value should be taken." annotatedElement="6cd3c6db-741f-41c9-9884-b8dbc5d1caf1"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="85d79651-8428-4706-9455-efd6b4dd85fc" name="base_Property" visibility="private" association="81fc9ad8-6eb2-4d79-8137-f3d098288022">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Property"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="193a62f5-18cc-419b-84c8-3ecfbe677a7a" name="technicalHeader" visibility="private">
        <ownedComment xmi:id="5e4a3fa1-4543-41cf-888b-270ca56e0083" body="If a header field is marked as a technical header then it will be part of the published API e.g. in the OpenAPI specification. However it will be hidden to the generated business code." annotatedElement="193a62f5-18cc-419b-84c8-3ecfbe677a7a"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="d4b56c4e-0ee6-4195-9d90-642a61c4ee82" name=""/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="564c5af0-c875-4ed8-993f-73de430d8600" name="" memberEnd="932577c7-5a81-4ce3-92f6-ff46ec0d47be 64dc445d-d455-40ea-b3e9-3274679692fb" navigableOwnedEnd="932577c7-5a81-4ce3-92f6-ff46ec0d47be">
