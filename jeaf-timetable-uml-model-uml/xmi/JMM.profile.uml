        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="81245312-c41a-44fd-a32f-a4847645258c" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="e09f1735-8477-40a8-8709-a3c9265ec949" name=""/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="0bc2c058-0731-41ea-ba76-2d067e26d1b6" name="ResponseHeaderGroup">
      <ownedComment xmi:id="65a1bd03-992f-4820-982b-d26043be5391" body="Stereotype `«ResponseHeaderGroup»` can be used to define response headers for OpenAPI specifications. To define response headers a class has to be modeled where every header field is a property. &#xA;&#xA;" annotatedElement="0bc2c058-0731-41ea-ba76-2d067e26d1b6"/>
      <ownedAttribute xmi:id="6a0503c0-4c03-4131-833c-4fc714217077" name="base_Class" visibility="private" association="def936c1-ce60-4caf-9500-28d9f65d295c">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
      </ownedAttribute>
    </packagedElement>
