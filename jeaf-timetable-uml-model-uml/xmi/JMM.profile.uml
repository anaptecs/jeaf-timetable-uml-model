    <packagedElement xmi:type="uml:Stereotype" xmi:id="ea4ae6c8-4015-45ff-bc42-d2360e4bc4d9" name="OpenAPIPattern">
      <ownedComment xmi:id="ff297fb5-5140-4b60-9b56-8cd7ed2b7ab0" body="Stereotype `«OpenAPIPattern»` can be used to define a pattern for the values of a property / parameter.&#xA;&#xA;*Note:*&#xA;When also working with Java, please be aware that syntax from JavaScript ([ECMA 262](https://www.ecma-international.org/ecma-262/5.1/#sec-15.10.1)) is used which is not compatible." annotatedElement="ea4ae6c8-4015-45ff-bc42-d2360e4bc4d9"/>
      <ownedAttribute xmi:id="234d8695-93f3-447f-ae85-1b854acb90eb" name="pattern" visibility="private">
        <ownedComment xmi:id="241b55aa-10fb-4db0-a85b-f6c2eb8a7078" body="Regular expression defining the pattern." annotatedElement="234d8695-93f3-447f-ae85-1b854acb90eb"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
