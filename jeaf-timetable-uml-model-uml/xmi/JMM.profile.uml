    <packagedElement xmi:type="uml:Stereotype" xmi:id="37fdb472-8b47-47c8-be09-b0b3b464743f" name="ObjectMapperFactory" clientDependency="11ba47b6-f9b5-44a6-b175-ac4088dabb80 6137cef9-6f6c-4840-b92b-5346eabbb9f9 29c24352-03d3-4414-a4be-e12d4c633022">
      <ownedComment xmi:id="ae3e387a-7c75-4953-a884-38bf5455e41d" body="Stereotype `«ObjectMapperFactory»` can be used to define a complete Jackson ObjectMapperFactory. An object mapper factory consists of one or more module factories. This connection is defined using dependencies in UML." annotatedElement="37fdb472-8b47-47c8-be09-b0b3b464743f"/>
      <ownedComment xmi:id="79cc201e-b33b-4c3e-a803-b07861ff2d23" body="For further information please refer to:&#xA;- [`«ModuleFactory»`](/uml-modeling-guide/jmm/ModuleFactory)" annotatedElement="37fdb472-8b47-47c8-be09-b0b3b464743f"/>
