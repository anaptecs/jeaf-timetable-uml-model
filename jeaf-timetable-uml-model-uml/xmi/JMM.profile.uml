      <ownedLiteral xmi:id="09f43843-0d4e-42fd-8742-54d953c12077" name="CUSTOM_DEFAULT_IMPLEMENTATION" classifier="704f933a-5ff1-45a4-8e75-bc06d122be57"/>
    </packagedElement>
    <packagedElement xmi:type="uml:Dependency" xmi:id="e9ef2217-45cc-4c34-bf38-da38e15ca729" name="" supplier="704f933a-5ff1-45a4-8e75-bc06d122be57" client="5526a16e-06e4-4b56-8464-5ca5041ed64c"/>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="d3c33a93-3a48-4cba-9013-b5b95011f930" name="AddToJSON">
      <ownedComment xmi:id="5da4f267-7d72-44a0-bd38-7a25a3f820c4" body="Stereotype `«AddToJSON»` is intended to be used for derived properties. By default they are not represented in the JSON representation of an object. Using this property however it is possible to add derived properties also to JSON and OpenAPI specification of a type." annotatedElement="d3c33a93-3a48-4cba-9013-b5b95011f930"/>
      <ownedAttribute xmi:id="40ca1add-28bd-46b9-94d4-fed69497558c" name="base_Property" visibility="private" association="c1613471-3a9d-410e-90d3-894bca3ab7d6">
