        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="c3b1c1ed-3c0c-4dc1-85fb-1c4d14d29e0c" name=""/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="6f6f8091-14cb-47b1-ad5f-55e33710f32d" name="QueryParam">
      <ownedComment xmi:id="0f52203a-290a-4a6a-9f36-e506ed3f07ed" body="Stereotype `«QueryParam»` is used to mark that a parameter of a REST operation should be taken from the query string of a REST request. &#xA;&#xA;Please be aware that the stereotype can only be applied on an operation of an interface that is marked as `«RESTResource»` and the operation is marked as `«RESTOperation»`." annotatedElement="6f6f8091-14cb-47b1-ad5f-55e33710f32d"/>
      <ownedAttribute xmi:id="c52dc76c-6b6a-449e-93cd-65ee45c2af34" name="base_Parameter" visibility="private" association="813b8c26-9932-45d3-9c1c-687ebebc2d43">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Parameter"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="1a0621b6-71c8-4a96-8b14-1f3bc1eb68e5" name="value" visibility="private">
        <ownedComment xmi:id="8dab4396-fa16-4572-8412-74bf409863f8" body="Name of the query parameter in the request. If it is not set then the name of the property / parameter will also be used as query param name." annotatedElement="1a0621b6-71c8-4a96-8b14-1f3bc1eb68e5"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="1ff2862c-ea8f-46a2-95ac-b30027dd36c7" name="base_Property" visibility="private" association="a0da8a2c-24a0-4f5d-8248-5d304b0edceb">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Property"/>
      </ownedAttribute>
    </packagedElement>
