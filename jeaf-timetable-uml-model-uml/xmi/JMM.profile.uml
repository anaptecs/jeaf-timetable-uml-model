    <packagedElement xmi:type="uml:Extension" xmi:id="a0da8a2c-24a0-4f5d-8248-5d304b0edceb" name="" memberEnd="7a22b7c2-a730-4803-8e34-4ee5227800f7 1ff2862c-ea8f-46a2-95ac-b30027dd36c7" navigableOwnedEnd="7a22b7c2-a730-4803-8e34-4ee5227800f7">
