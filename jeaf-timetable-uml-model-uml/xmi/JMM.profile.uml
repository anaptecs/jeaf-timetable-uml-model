    <packagedElement xmi:type="uml:Stereotype" xmi:id="034279fd-1efa-469d-9bf3-a1e2fd994106" name="OAuthScope">
      <ownedComment xmi:id="e7366c0c-431e-4e45-b14d-f5f190f1d489" body="Stereotype `«OAuthScope»` is used to define the scopes of a OAuth flow." annotatedElement="034279fd-1efa-469d-9bf3-a1e2fd994106"/>
      <ownedComment xmi:id="acb06af5-2e66-4271-b733-1a2222feb5ff" body="For further information please refer to:&#xA;- [OpenAPI - OAuth Flow](https://spec.openapis.org/oas/latest.html#oauth-flows-object)" annotatedElement="f244c284-004d-40a1-ae69-74e9352116ca"/>
      <ownedAttribute xmi:id="4e3380bd-3847-4789-ab7a-f075bc5cb4da" name="base_Component" visibility="private" association="8f7d0cc4-c20f-4125-a739-0edbe2538f32">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Component"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="654a2858-54bf-4df4-8a86-5e32929736c5" name="name" visibility="private">
        <ownedComment xmi:id="85db8927-a57e-47a0-a46a-a2d201d3285e" body="Name of the scope e.g. `write:pets`." annotatedElement="654a2858-54bf-4df4-8a86-5e32929736c5"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="01cea9b4-993b-4920-9d28-521dffd2c9a3" name="description" visibility="private">
        <ownedComment xmi:id="ac064a36-a2ae-4d91-9f2d-577cd8c6736d" body="Description of the scope e.g. `&quot;modify pets in your account&quot;`" annotatedElement="01cea9b4-993b-4920-9d28-521dffd2c9a3"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="8f7d0cc4-c20f-4125-a739-0edbe2538f32" name="" memberEnd="fd27b07c-978f-47ea-a718-490c7429f3d0 4e3380bd-3847-4789-ab7a-f075bc5cb4da" navigableOwnedEnd="fd27b07c-978f-47ea-a718-490c7429f3d0">
