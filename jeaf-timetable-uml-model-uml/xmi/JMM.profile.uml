    <packagedElement xmi:type="uml:Stereotype" xmi:id="2fe5ea87-4ad7-45cc-b335-09c919c88210" name="JSONAlias">
      <ownedComment xmi:id="ae5fec6b-3668-4036-a5e7-d1fa08f5ed9d" body="Stereotype `«JSONAlias»` is intended to be used for alternative names of properties in their JSON representation. This might especially helpful in case when you want to ensure SemVer for changes in your application." annotatedElement="2fe5ea87-4ad7-45cc-b335-09c919c88210"/>
