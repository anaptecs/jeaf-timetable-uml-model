    <packagedElement xmi:type="uml:Extension" xmi:id="3819cf9e-648e-4328-ab1a-0e6366954495" name="" memberEnd="a0ff9a25-c7be-42c1-b61d-4aa8e1ebdbbd 3cd5c585-4481-421c-b3a0-222cf94cb169" navigableOwnedEnd="a0ff9a25-c7be-42c1-b61d-4aa8e1ebdbbd">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="a0ff9a25-c7be-42c1-b61d-4aa8e1ebdbbd" name="extension_OpenAPI3" visibility="private" type="536b0817-10b9-4016-ada5-95254c9cea34" aggregation="composite" association="3819cf9e-648e-4328-ab1a-0e6366954495">
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="d63e066f-5e6d-47da-85be-1ea65542a298" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="0e2fa230-4bec-45c5-a336-5e8e0fec2f87" name=""/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="0e9e6cff-8489-46ca-808a-226df7b15f21" name="OpenAPIType">
      <ownedComment xmi:id="1874efa9-1604-46c3-97ff-0fff21f862bb" body="Stereotype `«OpenAPIType»` can be used to mark a class as OpenAPI data type. As no further information are required the stereotype does not define any tagged values." annotatedElement="0e9e6cff-8489-46ca-808a-226df7b15f21"/>
      <ownedAttribute xmi:id="1bbfe31e-dc67-4855-a5ba-dfafc6175f9d" name="base_Class" visibility="private" association="d3aefe3f-e242-4dce-9acc-8f91ffdb29cd">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="d3aefe3f-e242-4dce-9acc-8f91ffdb29cd" name="" memberEnd="49cac1f6-7eeb-46d9-8ff6-c00a15523e17 1bbfe31e-dc67-4855-a5ba-dfafc6175f9d" navigableOwnedEnd="49cac1f6-7eeb-46d9-8ff6-c00a15523e17">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="49cac1f6-7eeb-46d9-8ff6-c00a15523e17" name="extension_OpenAPIType" visibility="private" type="0e9e6cff-8489-46ca-808a-226df7b15f21" aggregation="composite" association="d3aefe3f-e242-4dce-9acc-8f91ffdb29cd">
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="e6bb1282-bb93-489f-97a1-972f6345c361" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="52a7e1d3-1794-47b3-8b72-352f6e72fafc" name=""/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="cc3211a9-65f9-4f7c-8a52-6bf6c59c7ba1" name="OpenAPIEnumeration">
      <ownedComment xmi:id="bb2bc19b-c71c-4a2b-9258-7a960999383e" body="Stereotype `«OpenAPIEnumeration»` can be used to mark an enumeration to be part of an OpenAPI specification.&#xA;&#xA;JEAF Generator also supports so called &quot;extensible enums&quot;. From a semantic versioning perspective added new literals to an enumeration is a breaking change. However in reality this is a quite common case. If you want to avoid the breaking change then you can work with extensible enums. By convention for them its not considered to be a breaking change if you add an additional literal.&#xA;&#xA;To support developers in this scenarios JEAF Generator is able to generate extensible enums. In such a case type `x-extensible-enum` is used instead of `enum`.&#xA;" annotatedElement="cc3211a9-65f9-4f7c-8a52-6bf6c59c7ba1"/>
      <ownedAttribute xmi:id="f65bc84a-80d4-4c8a-848b-b8b5c6e70e50" name="base_Enumeration" visibility="private" association="33efe6f9-dfb6-41bd-b329-51ef51d37213">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Enumeration"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="26bc1a8f-320f-4ff1-82d8-c7d434f27189" name="extensibleEnum" visibility="private">
        <ownedComment xmi:id="50125de6-d591-4baa-96f3-d962fb18f904" body="If set to `true` the enumeration is an extensible enum.&#xA;&#xA;Default value: `false`" annotatedElement="26bc1a8f-320f-4ff1-82d8-c7d434f27189"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="3ebc00c7-deb6-4b74-84dd-6ed55733528d" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="700fe1ee-3d34-49b1-9e61-236daacf8bc5" name="hasDynamicLiterals" visibility="private">
        <ownedComment xmi:id="988e6b92-9933-4be0-a88e-f4a2120efe82" body="Typically enumeration literals are directly defined on an enumeration in the UML model. However, there might be cases where the literals should be resolved from somewhere else.&#xA;&#xA;For such cases JEAF Generator allows to dynamically resolve literals. Therefore, in addition to setting this tag to `true` also  `jeafgenerator/api/OpenAPIEnumExtensionPoint.ext` has to be implemented. There the dynamic literals have to be returned by function `List[String] getDynamicLiteralNames(JMM::OpenAPIEnumeration enum)`.&#xA;&#xA;It is also supported to mix model defined and dynamic literals." annotatedElement="700fe1ee-3d34-49b1-9e61-236daacf8bc5"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="c9ea5b80-d31a-4f91-a99d-8a5affa360b1" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="3ba54a69-2160-4edd-a1be-bdec464569e2" name="inline" visibility="private">
        <ownedComment xmi:id="ca2962cf-c5de-49ca-b939-5a2e7df149fa" body="Tagged value can be used to inline enums inside OpenAPI specifications.&#xA;&#xA;Please be aware that even though this is possible it is considered to be bad style as it may lead to multiple enums of actually the same type in the OpenAPI spec and also code that might be generated based on it." annotatedElement="3ba54a69-2160-4edd-a1be-bdec464569e2"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="d92783b1-5d90-443b-b2b0-06da9fafbdc1" name=""/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="33efe6f9-dfb6-41bd-b329-51ef51d37213" name="" memberEnd="7093a511-6df7-4cd2-a186-c13cdd4f2529 f65bc84a-80d4-4c8a-848b-b8b5c6e70e50" navigableOwnedEnd="7093a511-6df7-4cd2-a186-c13cdd4f2529">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="7093a511-6df7-4cd2-a186-c13cdd4f2529" name="extension_OpenAPIEnumeration" visibility="private" type="cc3211a9-65f9-4f7c-8a52-6bf6c59c7ba1" aggregation="composite" association="33efe6f9-dfb6-41bd-b329-51ef51d37213">
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="279a1d0c-9b1d-4cc8-ace6-ab7a3408aed8" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="21edca68-be73-4840-bbad-5ca660f8e1b9" name=""/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="a7b20a93-d16c-43f5-bb60-010cc69c2615" name="OpenAPIServer">
      <ownedComment xmi:id="3f31490f-3ca1-4c78-bc86-92a4081188db" body="When defining an OpenAPI specification it is also possible to define the servers on which the API is available. For each server a component with stereotype `«OpenAPIServer»` needs to be defined." annotatedElement="a7b20a93-d16c-43f5-bb60-010cc69c2615"/>
      <ownedAttribute xmi:id="f6c7a739-be92-43b3-9026-9b5ace4f385a" name="base_Component" visibility="private" association="f93cab04-66bd-45d9-8e8b-8a6ef68b0bce">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Component"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="f06854a3-6c62-4961-9636-3f8f9ff43201" name="url" visibility="private">
        <ownedComment xmi:id="400255ed-c109-49b4-b944-2d06c7650fb0" body="URL under which the server is available." annotatedElement="f06854a3-6c62-4961-9636-3f8f9ff43201"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="356ba240-f0f9-4f2d-a95a-98f008af7cfd" name="order" visibility="private">
        <ownedComment xmi:id="e34e9855-9136-441e-9dea-04ef110cf9b8" body="Attribute can be used to define a stable order within the defined OpenAPI server instances within a specification file." annotatedElement="356ba240-f0f9-4f2d-a95a-98f008af7cfd"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
        <defaultValue xmi:type="uml:LiteralInteger" xmi:id="a45a7f29-e2b8-4e91-a301-28e6a364bc71" name=""/>
