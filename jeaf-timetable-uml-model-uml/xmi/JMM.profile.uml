        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="f7cc05bf-ec93-44d8-87da-063a97bf26d1" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="5e0e5c95-acf5-467e-8c1b-105a280853a0" name="readOnly" visibility="private">
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="d45b7594-cfb1-44e5-80a6-16a4cb1de3e5" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="4ebd4922-4fdf-44bd-8375-da8b4359d23c" name="validateOnBuild" visibility="private">
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="aabc1541-41e2-4c94-9d5f-1358b96e57a6" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="5550c28f-c452-439a-9e85-9923f663e3e3" name="ofMethod" visibility="private" type="4bc20ac0-b2cb-41e6-8e81-4ef1950dc013">
        <defaultValue xmi:type="uml:InstanceValue" xmi:id="e5e10dd3-f09c-4f99-9b01-7735d6cdf1a3" name="" instance="dc206951-639e-4f1a-84f9-509e981294b4"/>
      </ownedAttribute>
