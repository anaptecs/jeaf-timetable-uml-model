      </ownedAttribute>
      <ownedAttribute xmi:id="9f310113-de57-4115-ba91-8d6cba1a2a8c" name="openAPIPropertyName" visibility="private">
        <ownedComment xmi:id="8b62c678-0f01-4daf-bfbb-2f758135e64c" body="Name that should be used for a property in OpenAPI specification and JSON representation." annotatedElement="9f310113-de57-4115-ba91-8d6cba1a2a8c"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
