    <packagedElement xmi:type="uml:Stereotype" xmi:id="20bc3a5e-001d-4a44-a6f6-6379186a1325" name="OpenAPIAliasName">
      <ownedComment xmi:id="c1c8a770-7dc7-4972-af66-45fb323efdc9" body="Stereotype `«OpenAPIAliasName»` can be used to define a different name for a property in OpenAPI specification and generated JSON on the one side and Java code on the other." annotatedElement="20bc3a5e-001d-4a44-a6f6-6379186a1325"/>
      <ownedAttribute xmi:id="e80da1b2-1870-4246-a091-29cfe0b15634" name="base_Property" visibility="private" association="3957012c-7038-4ac5-810c-8edb7f701bac">
