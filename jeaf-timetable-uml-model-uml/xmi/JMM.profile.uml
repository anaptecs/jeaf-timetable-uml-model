    <packagedElement xmi:type="uml:Stereotype" xmi:id="07c39637-e047-4e40-ae76-6fbec9664357" name="MavenProjectDependency">
      <ownedComment xmi:id="37c1b293-8289-4d5b-8f34-557438bbd00c" body="The stereotype `«MavenProjectDependency»` can be used to specify dependencies within multi-module projects. In such cases, it is necessary to define between which modules the dependencies actually exist." annotatedElement="07c39637-e047-4e40-ae76-6fbec9664357"/>
      <ownedAttribute xmi:id="577c28be-8cfa-4d36-bec2-be8f4ffdcb2a" name="base_Dependency" visibility="private" association="ab5689ff-bc14-467e-b9c4-65409fa5cba7">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="f363c75f-13b5-42b8-ae1a-72640b7dc826" name="moduleDependencyTypes" visibility="private" type="8fb32bb2-dd19-4c61-ad43-e87767ecccb7" association="25bb7d4f-e79f-4249-8aa8-ef8055584144">
        <ownedComment xmi:id="df77d167-04e4-4c9f-920f-ea07af508969" body="This tag can be used to define the dependencies between the related Maven projects at the module level.&#xA;&#xA;At least one module dependency type must be defined." annotatedElement="f363c75f-13b5-42b8-ae1a-72640b7dc826"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="6d89542a-ffd2-4bae-b0fd-6b138057dd72" name="" value="*"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="49e1a2c0-5f73-4b62-8297-a538792f9064" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="8a9ba985-d43d-452c-a02f-c40ffc2b9cbc" name="order" visibility="private">
        <ownedComment xmi:id="fbcaae3a-4b5c-4e90-b4dd-fda8258ec19b" body="This tag can be used to define the order of this dependency among all other `MavenDependency` definitions within the project." annotatedElement="8a9ba985-d43d-452c-a02f-c40ffc2b9cbc"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
        <defaultValue xmi:type="uml:LiteralInteger" xmi:id="ce3786da-2f8c-4048-921a-740ef1f0e793" name="" value="1000"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="95ffc6a8-c58d-4972-a1db-1bc94da40611" name="MavenParentPOM">
      <ownedComment xmi:id="919436e6-855b-489f-b131-6f97d6752782" body="The stereotype `«MavenParentPOM»` can be used to define the parent POM for a Maven project." annotatedElement="95ffc6a8-c58d-4972-a1db-1bc94da40611"/>
      <ownedAttribute xmi:id="0c006745-efd7-46d7-8e44-40f134ab5280" name="base_Dependency" visibility="private" association="add0fc39-aa11-4642-affd-738c407b4503">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="e08893f8-16d0-40ee-b26f-7f3ddf0877fc" name="CompatibilityGroup">
      <ownedComment xmi:id="0da08195-59fb-4066-a158-d349d254109c" body="The stereotype `«CompatibilityGroup»` can be used to group constraints that apply to specific versions of an API.&#xA;&#xA;To achieve this, each property that belongs to a compatibility group must define a dependency on that group. Constraints can then be specified on this dependency that differ from the constraints defined directly on the property. This makes it possible to define version-specific constraints.&#xA;&#xA;Default constraints are defined directly on the property, while version-specific constraints are defined on the dependency." annotatedElement="e08893f8-16d0-40ee-b26f-7f3ddf0877fc"/>
      <ownedAttribute xmi:id="d6d14bfc-6003-4b63-90c9-a3bdcb8a32ce" name="base_Component" visibility="private" association="3c7e95f9-2431-4aa3-b278-509cae1f0e46">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Component"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="3e4e9cb3-7c1f-44fc-b918-bdbf1e059eb5" name="sunsetDate" visibility="private">
        <ownedComment xmi:id="51e686b3-2a43-490e-a4fb-c2fc12a07d67" body="The date until which this compatibility group will be in use. The sunset date indicates the date until which compatibility with a specific API version will be supported.&#xA;&#xA;The expected date format is `yyyy-mm-dd`." annotatedElement="3e4e9cb3-7c1f-44fc-b918-bdbf1e059eb5"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
