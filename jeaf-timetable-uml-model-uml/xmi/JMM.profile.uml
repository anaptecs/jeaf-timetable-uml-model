      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="139596c9-7eea-48f6-9fc1-30448dfe1b0f" name="" memberEnd="0474e4e6-e731-4adb-b86d-b9e6ca3b9557 7c36b109-1b32-4e79-966c-eefa16a65cde" navigableOwnedEnd="0474e4e6-e731-4adb-b86d-b9e6ca3b9557">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="0474e4e6-e731-4adb-b86d-b9e6ca3b9557" name="extension_Entity" visibility="private" type="a72b2444-b8dc-4507-8341-496b0848db7a" aggregation="composite" association="139596c9-7eea-48f6-9fc1-30448dfe1b0f">
        <upperValue xmi:type="uml:LiteralInteger" xmi:id="797eb776-8b9b-4407-bdd3-0d4761ae7dd6" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="43658a11-0785-4adb-ba56-9b894718e17a" name=""/>
