        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="0f4de77b-419e-4669-97f9-97d1028411a9" name=""/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="eb014fdb-7dc3-4d0d-a16f-80436930c65a" name="" memberEnd="31eb7fb9-470a-45a9-9e5a-30b8734b802d c4ec0339-5050-4b88-859c-85a96aff46c9" navigableOwnedEnd="31eb7fb9-470a-45a9-9e5a-30b8734b802d">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="31eb7fb9-470a-45a9-9e5a-30b8734b802d" name="extension_CookieParam" visibility="private" type="915148cd-2bd2-4a4d-a026-46217ada24c1" aggregation="composite" association="eb014fdb-7dc3-4d0d-a16f-80436930c65a">
