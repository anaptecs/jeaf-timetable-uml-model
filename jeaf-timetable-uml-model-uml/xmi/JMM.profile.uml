        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="94dbafbb-d428-4131-a0b8-5dba2c18eb9d" name=""/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="b54b24ba-4ef7-4369-a119-eda03bba7289" name="Ordered">
      <ownedComment xmi:id="5fadd05d-2c88-4c52-82fc-7fae659dce82" body="Stereotype `«Ordered»` can be used to define the order of elements e.g. in an OpenAPI specification.&#xA;&#xA;Notes:&#xA;&#xA;- Explicit ordering must be enabled in OpenAPI specifications using `OpenAPISpecification.explicitTypeOrdering = true` or `OpenAPISpecification.explicitPathOrdering = true`." annotatedElement="b54b24ba-4ef7-4369-a119-eda03bba7289"/>
      <ownedAttribute xmi:id="2f373db4-91a0-4e08-817e-ebefb01ae7c4" name="base_Element" visibility="private" association="ef9922e5-9ec6-471b-81e3-f2fecbb55ed3">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Element"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="9af43783-a47b-45dd-ad07-ba5a7416105b" name="order" visibility="private">
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
        <defaultValue xmi:type="uml:LiteralInteger" xmi:id="1f970927-dcf4-4a23-85bc-d8913aae4763" name="" value="9999"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="ef9922e5-9ec6-471b-81e3-f2fecbb55ed3" name="" memberEnd="e20add4f-0354-4f9e-a2e2-aa4c84dc275a 2f373db4-91a0-4e08-817e-ebefb01ae7c4" navigableOwnedEnd="e20add4f-0354-4f9e-a2e2-aa4c84dc275a">
