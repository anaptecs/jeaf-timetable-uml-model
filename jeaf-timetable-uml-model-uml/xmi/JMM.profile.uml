    <packagedElement xmi:type="uml:Stereotype" xmi:id="490d7836-5e91-42ac-86e6-d6904aaf8269" name="CompositeDataTypePublicField">
      <ownedComment xmi:id="6b8a6a9b-1530-4f81-80e0-14d25b3eb5d9" body="Stereotype `«CompositeDataTypePublicField»` can be used for the name of the public field which acts as public representation of a composite data type." annotatedElement="490d7836-5e91-42ac-86e6-d6904aaf8269"/>
