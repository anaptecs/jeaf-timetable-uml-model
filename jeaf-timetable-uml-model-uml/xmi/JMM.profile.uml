    <packagedElement xmi:type="uml:Stereotype" xmi:id="686e2fec-54f1-4320-b441-006fad63e93e" name="OpenAPITypeMapping">
      <ownedComment xmi:id="feb166e7-78d7-4a97-ba7f-e31a7c79d3a7" body="Stereotype can be used to define special type mappings for OpenAPI and its JSON representation." annotatedElement="686e2fec-54f1-4320-b441-006fad63e93e"/>
      <ownedAttribute xmi:id="23104723-ce22-4c8a-b8b2-b19bba965d80" name="base_Class" visibility="private" association="9b1846d0-8c20-41bc-9173-0ad93feb49d5">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="06414c0e-852d-4913-9f1c-95d2095abb1a" name="discriminatorPropertyName" visibility="private">
        <ownedComment xmi:id="e96df76d-b3d4-487c-a26f-b3e98ed59b3b" body="Tagged value can be used to define the name of the discriminator property that is used in JSON to transport type information in case of inheritance. By default `objectType` will be used as name.&#xA;&#xA;This tagged value only makes sense to be set on types that are the top level element of an inheritance hierarchy." annotatedElement="06414c0e-852d-4913-9f1c-95d2095abb1a"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <defaultValue xmi:type="uml:LiteralString" xmi:id="2aa4b6ca-d309-4b99-be72-63ec255e7092" name="" value="&quot;objectType&quot;"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="72837b85-e2d1-4da5-b01b-b750a95dab10" name="discriminatorValue" visibility="private">
        <ownedComment xmi:id="97c80420-bb9f-43b9-94d0-435d0f3ef3a2" body="Tagged value can be used to define a special discriminator value for a class inside a inheritance hierarchy. If the tagged value is not set then the simple name of the type will be used." annotatedElement="72837b85-e2d1-4da5-b01b-b750a95dab10"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="9b1846d0-8c20-41bc-9173-0ad93feb49d5" name="" memberEnd="e38e8ded-f8ac-4378-9978-493883bfbb2d 23104723-ce22-4c8a-b8b2-b19bba965d80" navigableOwnedEnd="e38e8ded-f8ac-4378-9978-493883bfbb2d">
