    <packagedElement xmi:type="uml:Stereotype" xmi:id="dba37e3a-d310-4806-99c6-023edd567542" name="ReleaseDependency" clientDependency="b58d5586-0b95-446b-a911-d4cb41e42575">
      <ownedComment xmi:id="9d77e573-ad8d-41de-9ee3-b15985532653" body="The stereotype `«ReleaseDependency»` can be used to define dependencies between release units. This mechanism is intended to simplify the modeling of such dependencies.&#xA;&#xA;It allows dependencies to be specified at the level of release units, thereby avoiding the need to define them repeatedly for each individual release." annotatedElement="dba37e3a-d310-4806-99c6-023edd567542"/>
      <ownedAttribute xmi:id="875cb808-11f5-4d09-88ad-760fce14688d" name="base_Dependency" visibility="private" association="52c77428-ee27-44ea-b8d4-cbca8ac3aa56">
