    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="237fee21-2f72-45a5-8e7c-a36043c94f7f" name="Alias">
      <ownedComment xmi:id="d432e97b-65e8-4cd6-9a9f-236e1e84c111" body="Stereotype `«Alias»` can be used to express that a model element also has an alternative name. This might be helpful in case that there is a renaming of elements. Alternate name might be displayed in model report." annotatedElement="237fee21-2f72-45a5-8e7c-a36043c94f7f"/>
