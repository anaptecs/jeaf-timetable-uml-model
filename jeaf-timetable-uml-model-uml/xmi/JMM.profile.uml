    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="83597888-de29-4796-80ce-61c1f92d535b" name="MavenDependency">
      <ownedComment xmi:id="800ee86d-3147-4739-a97d-3e2c3325794b" body="The stereotype `«MavenDependency»` can be used to define a dependency between a Maven project and a specific Maven artifact.&#xA;&#xA;This stereotype can only be applied on dependencies where the target Maven project is of archetype `ARTIFACT`." annotatedElement="83597888-de29-4796-80ce-61c1f92d535b"/>
      <ownedAttribute xmi:id="f47ed0a3-1ad0-417d-bea6-b7a3c4dbe444" name="base_Dependency" visibility="private" association="6c41b4ee-a38b-46da-a668-411b1cffb984">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="fa11579c-ad69-40b0-90d8-fa5d6b172a37" name="customModuleTypes" visibility="private">
        <ownedComment xmi:id="a7d69b5c-cbc5-4c71-94c8-6f37f9fcd44a" body="A value for this tag only needs to be defined if `sourceModuleType = CUSTOM` is selected. In that case, the name of the custom module must be specified." annotatedElement="fa11579c-ad69-40b0-90d8-fa5d6b172a37"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="d0db596c-d765-45aa-bc6d-c67d42250657" name="" value="*"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="c3495159-aa16-4483-b65e-2db6597ea38a" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="ddfc8147-2688-4cc3-b009-0ee08802b4e8" name="packaging" visibility="private" type="acea2c02-924d-4dce-9fda-38908e47c5c2" association="1613b649-0a56-430c-8bb3-8fd3f4d5b9ff">
        <ownedComment xmi:id="8990e250-9470-4dd8-b1b7-8ff4ce568463" body="Type of the target artifact that should be used. &#xA;&#xA;If nothing is defined then Maven defaults will be used." annotatedElement="ddfc8147-2688-4cc3-b009-0ee08802b4e8"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="55e5d6f5-8f5b-4bdf-90e4-517046ed84cd" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="00368e81-a57d-4fbd-bef1-0276dd518283" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="c1e17312-75d9-4ffc-9838-a910cbc82d5c" name="scope" visibility="private" type="de061f7d-74c4-4d8e-bc97-b0b39967e1d3" association="0e6ccef2-5456-4886-bf56-14fbd86871ba">
        <ownedComment xmi:id="98c7e0e7-4179-4ee5-a9dd-31d80fb6862c" body="Scope within which the target artifact should be used." annotatedElement="c1e17312-75d9-4ffc-9838-a910cbc82d5c"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="2bc5b6da-02cf-49f7-86b4-77f65bafd6d9" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="954bd947-2c08-4529-aec2-90ea4f6fc90f" name=""/>
        <defaultValue xmi:type="uml:InstanceValue" xmi:id="ea1335df-5bfd-4cb7-a5e3-304f5c9b7610" name="" instance="cf0a14ec-dfed-4d54-b4a0-001b496a87c4"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="1719d380-fbcb-445f-8f76-e522ab198927" name="order" visibility="private">
        <ownedComment xmi:id="bfb16dce-2dcd-4456-94ca-ae7130ca0f59" body="This tag can be used to define the order of this dependency among all other `MavenDependency` definitions within the project." annotatedElement="1719d380-fbcb-445f-8f76-e522ab198927"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
        <defaultValue xmi:type="uml:LiteralInteger" xmi:id="39fd7343-8f51-41f1-a99a-ed8b34a97be3" name="" value="1000"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="ec05ae12-b1c0-4dfd-a501-f6673845ba48" name="sourceModuleTypes" visibility="private" type="5ab67eac-5622-40e2-9418-eca98087aa85" association="3d472d2d-7aa1-44e1-8680-83874aced4be">
        <ownedComment xmi:id="f8aa0323-d114-4579-b335-31b78c9d1071" body="List of source module types that have a dependency on the target artifact. At least one source module type must be defined." annotatedElement="ec05ae12-b1c0-4dfd-a501-f6673845ba48"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="f85dc8e1-57ba-4f15-974a-4bdb0a0b39e8" name="" value="*"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="d267b28a-d823-4e12-8e6d-3a7221dd043d" name=""/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="df0e503a-8dfe-4068-a9fd-7f8b5c3d26b1" name="MavenProject">
      <ownedComment xmi:id="965fe6cb-9597-40bc-af04-83183fae4a07" body="The stereotype `«MavenProject»` can be used to add Maven-specific information to an artifact. Based on the provided information, JEAF Generator will then be able to generate Maven project structures from the UML model." annotatedElement="df0e503a-8dfe-4068-a9fd-7f8b5c3d26b1"/>
      <ownedAttribute xmi:id="85632717-644c-4a8d-9e24-770d72d8228f" name="archetype" visibility="private" type="0eed3b88-6831-4599-97c3-bf80d8c8abe3" association="4b2ebc7d-c9f3-4b9b-8117-a1698040311d">
        <ownedComment xmi:id="02703a15-7fe7-4d8d-ba8b-573c16ed1e95" body="JEAF Generator supports several project archetypes. The archetype defines the general structure of a Maven project and, in particular, all the modules that a project will contain." annotatedElement="85632717-644c-4a8d-9e24-770d72d8228f"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="0ba96be3-1a72-4a43-813e-08df2ab9ba92" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="a217d49e-cfba-4dbe-ad53-77660f99ee6f" name="" value="1"/>
        <defaultValue xmi:type="uml:InstanceValue" xmi:id="1bf42e11-0393-428b-8609-a7a920c472b2" name="" instance="779d0339-c9be-433f-8c23-5ee2a0722494"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="558db4cd-4dde-4050-8b22-65e5a44b0f7a" name="serviceTypes" visibility="private" type="1e195e1c-ae70-4c5e-a0c7-9d9b8f047e95" association="5efbd043-9766-404f-be6f-7121215123c1">
        <ownedComment xmi:id="f0074910-bc4e-45e7-b429-d580cf6ecee8" body="If a Maven project uses the archetype `SERVICE_MODEL`, this tag can be used to define which types of services should be supported.&#xA;&#xA;By default, both synchronous and reactive services are supported." annotatedElement="558db4cd-4dde-4050-8b22-65e5a44b0f7a"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="e3b35e65-8c51-41dc-b557-42437ab8307d" name="" value="*"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="39d33822-85c3-4650-950e-c4b935adfa9f" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="8694e4c1-fa7e-426b-bb3a-e0113efb4a9d" name="groupId" visibility="private">
        <ownedComment xmi:id="146055b3-d272-445c-971a-f4734ba826fe" body="Group ID of the Maven artifact. If no value is defined here, a group ID will be derived based on the configured naming pattern.&#xA;&#xA;By default, the fully qualified package name will be used." annotatedElement="8694e4c1-fa7e-426b-bb3a-e0113efb4a9d"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="a03a38f4-61cb-4988-b4bd-fc0df997f369" name="artifactId" visibility="private">
        <ownedComment xmi:id="595daaf9-40eb-408f-9a8e-a2983c575f2a" body="Artifact ID of the Maven artifact. If no value is defined here, an artifact ID will be derived based on the configured naming pattern.&#xA;&#xA;By default, the name of the artifact’s UML element will be used. The element’s name will be converted to lower case, and all spaces will be replaced with “-” to comply with Maven naming conventions." annotatedElement="a03a38f4-61cb-4988-b4bd-fc0df997f369"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="ef194985-fd17-4b82-b441-baa4881bc14f" name="projectURL" visibility="private">
        <ownedComment xmi:id="5636605b-d22a-43bb-a8ca-f07dd34e6d5c" body="This tag can be used to specify a project URL, as defined in a Maven POM.&#xA;&#xA;If no value is provided here, the configured pattern for project URLs will be used. By default, no project URL will be set." annotatedElement="ef194985-fd17-4b82-b441-baa4881bc14f"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="27308d8a-74e7-482c-ba27-7f5ae6dd948a" name="base_Artifact" visibility="private" association="78a4a9ec-27b8-4bbe-a729-4ef5219f30b2">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Artifact"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="d02f20f0-040c-4c63-8b9b-710d364ff210" name="scmType" visibility="private" type="371f2ef8-c67b-4ea2-b8ce-673a77bfd02c" association="a9cac2ba-44cf-4369-90a8-6e0f0e5d2e24">
        <ownedComment xmi:id="36264225-d47d-46b3-8d90-25bbb6e80616" body="This tag can be used to specify the SCM type that is used.&#xA;&#xA;By default, `GIT` will be used." annotatedElement="d02f20f0-040c-4c63-8b9b-710d364ff210"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="1964008a-a987-4b96-9233-b8f345320952" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="af827b08-6e06-41dd-ab5e-2edcddfe829c" name="" value="1"/>
        <defaultValue xmi:type="uml:InstanceValue" xmi:id="39264f83-09fc-48a0-bb7b-bd86d03280ef" name="" instance="2591e9df-43da-4aa0-a735-d98e463ca269"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="c865d669-6b93-4c9d-8109-efc11e5b6a8d" name="scmPath" visibility="private">
        <ownedComment xmi:id="b77dab69-42f7-4bab-b672-f1c9674ffb94" body="This tag can be used to define the SCM path, as supported in a Maven POM. If no value is specified here, the configured SCM path pattern will be used.&#xA;&#xA;By default, no SCM path will be defined in the generated POM file.." annotatedElement="c865d669-6b93-4c9d-8109-efc11e5b6a8d"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="af8fe97a-bdf7-4eaf-83bb-dd0191f40e9d" name="customizable" visibility="private">
        <ownedComment xmi:id="490b4a83-0027-4fc0-9a8d-9c04781ab09f" body="This tag specifies whether the generated POMs for this artifact should be customizable.&#xA;&#xA;If the tag is set to `true`, the generated POM files will include several so-called protected regions where customizations can be made. Since the generated POM files work out of the box in almost all cases, it is recommended to enable this option only when truly necessary." annotatedElement="af8fe97a-bdf7-4eaf-83bb-dd0191f40e9d"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="75dba6b8-a703-478c-a237-fe71e9e16d92" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="e0b9dee3-e88c-4353-9ecc-2c740ac28c31" name="customArchetypeName" visibility="private">
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="e55b633a-8915-437e-9bf3-fc8cfa2bbb7c" name="modelCoordinatesSource" visibility="private" type="ce330ea8-9e8e-413f-a1d4-a4026d0d0cfd" association="9b7b29e2-1873-4ad1-a71d-dd4ef839aff2">
        <ownedComment xmi:id="ef30dd77-7c99-408c-8de8-91d13eaeca36" body="Tag defines from where coordinates for UML model lookup are taken.&#xA;&#xA;The following options are available:&#xA;* `USE_FROM_PARENT_POM`: Use UML model coordinates from parent POM&#xA;* `USE_OWN`: UML model coordinates should be defined within this Maven project&#xA;* `USE_PARENT_OR_OWN`: Use coordinates from parent POM if applicable. If not then they should be defined within this Maven project.&#xA;* `NONE`: Within this Maven project no UML model coordinates should be defined.&#xA;* `USE_DEFAULT`: Use default settings as defined in configuration of JEAF Generator Maven Plugin." annotatedElement="e55b633a-8915-437e-9bf3-fc8cfa2bbb7c"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="a15f9d06-36de-4571-8efa-1fb4dd21a3c5" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="7775948f-841b-4756-bac8-fa9b80b1bf0e" name="" value="1"/>
