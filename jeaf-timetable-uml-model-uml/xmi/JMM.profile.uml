    <packagedElement xmi:type="uml:Stereotype" xmi:id="34debe8b-d6de-48d0-9e98-0e86ba76a736" name="RESTResource" clientDependency="55f8d7a8-784e-4bab-9944-5d9a0b7e7976">
      <ownedComment xmi:id="8e11d431-4703-4b92-b521-eec23dbd863f" body="Stereotype `«RESTResource»` can be used to mark a service to also expose his operations at least partially also as REST Resource. &#xA;&#xA;Please be aware that the stereotype only makes sense to be used on interfaces that are marked as service using stereotype `«JEAFService»`." annotatedElement="34debe8b-d6de-48d0-9e98-0e86ba76a736"/>
      <ownedComment xmi:id="d10e9c22-388f-449c-9d3d-0a978775fc59" body="For further information please refer to:&#xA;- [How to model REST Services](/uml-modeling-guide/how-tos/how-to-model-rest-service-apis)&#xA;- [Generating Code for REST Services](/developer-guide/code-for-jeaf-services)" annotatedElement="ce0c25dc-f145-4481-9c2c-2e8bf365c18b"/>
      <ownedAttribute xmi:id="4a9f2320-81bc-47b1-b8f6-56de21e794be" name="base_Interface" visibility="private" association="88be3906-c82b-4839-92ba-0e8f2b1148db">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Interface"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="b0518c1f-9b98-4197-8534-efaee3648005" name="path" visibility="private">
        <ownedComment xmi:id="e00775f5-4a1d-46f2-8416-8890f2d7212a" body="Path under which the REST resource should be available. The attribute is optional. However as from a REST perspective it’s a best practice to define it. So it’s strongly recommended to do so already in the UML model." annotatedElement="b0518c1f-9b98-4197-8534-efaee3648005"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="5ad0cdee-c811-4ec6-9123-8e34003d2fee" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="a9382721-7f5a-4f07-84d6-6bf1cd1058e7" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="89879512-5d64-4f6c-81ae-2b35cea1c02e" name="operationPathPrefix" visibility="private">
        <ownedComment xmi:id="eb247d7a-f483-47fc-a950-777d5e579978" body="Path prefix for operation will be added to every operation of the service. No separators etc. will be added by JEAF Generator." annotatedElement="89879512-5d64-4f6c-81ae-2b35cea1c02e"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="36a53a0f-d443-48f2-ab98-4136a68a4838" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="b2ed3722-800c-47c5-91d3-71130949ca1e" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="9aebeac4-3742-4d91-b8e7-955d14843f65" name="produces" visibility="private" type="73fc7d84-9592-4c14-85cf-62ae3fd11f4f">
        <ownedComment xmi:id="9f8b3502-e60f-49af-b320-87000264ddf3" body="Optional definition of the media types that are used to encode the responses of the REST calls (e.g. `JSON`, `XML` etc.)." annotatedElement="9aebeac4-3742-4d91-b8e7-955d14843f65"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="a82f3b97-e891-4a7c-8720-27e02bca5baf" name="" value="*"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="af34eddd-f457-4c86-be03-463a609f405c" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="ab0fb171-9570-4d95-8da0-e0740dce6cb7" name="consumes" visibility="private" type="73fc7d84-9592-4c14-85cf-62ae3fd11f4f">
        <ownedComment xmi:id="85aa1268-692c-48e9-939f-be18ca36eca2" body="Optional definition of the media types that are supported to be used to encode REST requests (e.g. `JSON`, `XML` etc.)." annotatedElement="ab0fb171-9570-4d95-8da0-e0740dce6cb7"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="ce7af9cb-e6be-4099-bcf4-b7bb7e00079b" name="" value="*"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="d3bf462c-e62d-4f88-94af-b45d7c4d8fa6" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="a2ff0765-b785-4224-8eaf-7c36c434216a" name="async" visibility="private">
        <ownedComment xmi:id="6f7afdee-fa22-49cf-a457-c4bf15e9ab1c" body="Tagged value defines if the generated REST Resource / Controller should make use of server-side async processing.&#xA;&#xA;Please be aware that async processing is not supported by all target platforms." annotatedElement="a2ff0765-b785-4224-8eaf-7c36c434216a"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="7d018208-b843-49fe-8583-6c4446c957e9" name="" value="1"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="653177b3-89b7-4a07-8cca-969aa42611fb" name=""/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="88be3906-c82b-4839-92ba-0e8f2b1148db" name="" memberEnd="7e08ad00-6742-426d-a8a5-d96301cb0557 4a9f2320-81bc-47b1-b8f6-56de21e794be" navigableOwnedEnd="7e08ad00-6742-426d-a8a5-d96301cb0557">
