      <ownedLiteral xmi:id="4aa2a877-e984-4bc9-a945-1c99fa4f1f05" name="INDIVIDUAL_PROPERTY" classifier="3104ec1e-fe57-4a86-a43a-d16cbfcf8b39"/>
