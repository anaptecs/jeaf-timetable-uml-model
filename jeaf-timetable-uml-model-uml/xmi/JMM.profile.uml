    <packagedElement xmi:type="uml:Stereotype" xmi:id="f244c284-004d-40a1-ae69-74e9352116ca" name="OAuthFlow" clientDependency="9c5cdc74-9227-46b3-8f32-c89280a4644a">
      <ownedComment xmi:id="da4016b3-f63f-48bf-80e6-d27b02deac43" body="Stereotype `«OAuthFlow»` can be used to define the authentication part of an OpenAPI specification." annotatedElement="f244c284-004d-40a1-ae69-74e9352116ca"/>
      <ownedComment xmi:id="5a7201bb-5ad1-4557-a61f-ff297a84969f" body="For further information please refer to:&#xA;- [OpenAPI - OAuth Flow](https://spec.openapis.org/oas/latest.html#oauth-flows-object)" annotatedElement="f244c284-004d-40a1-ae69-74e9352116ca"/>
      <ownedAttribute xmi:id="d98c967d-70cb-4325-8e52-099d556efea0" name="base_Component" visibility="private" association="1f2cd12a-6ba0-48ad-a36f-b8c3a2f26f02">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Component"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="4e911dd8-4a56-461a-9dc8-6356b37d0eb1" name="flowType" visibility="private" type="cb0f96a0-5252-44af-9a0f-c4a72f17a861">
        <ownedComment xmi:id="25a6572c-9e05-4efe-939c-3e0660ffbc69" body="OAuth flow type that should be used. &#xA;&#xA;The following types are supported: `implicit`, `password`, `clientCredentials` and `authorizationCode`" annotatedElement="4e911dd8-4a56-461a-9dc8-6356b37d0eb1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="f95a712c-b661-4b0e-813e-df10d4906479" name="authorizationURL" visibility="private">
        <ownedComment xmi:id="34b2a6ef-2baf-424e-831f-a90f326b4a55" body="The authorization URL to be used for a flow. This must be in the form of a URL. The OAuth2 standard requires the use of TLS." annotatedElement="f95a712c-b661-4b0e-813e-df10d4906479"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="c9db2896-4209-412b-99db-f5b65670f213" name="tokenURL" visibility="private">
        <ownedComment xmi:id="73db52f0-be71-4bcd-baf2-f4fe991880f5" body="The token URL to be used for a flow. This must be in the form of a URL. The OAuth2 standard requires the use of TLS." annotatedElement="c9db2896-4209-412b-99db-f5b65670f213"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="870bda1d-e9ad-483d-9bd7-be0348fb08a7" name="refreshURL" visibility="private">
        <ownedComment xmi:id="63e34f48-27f8-4166-a176-c5d6c219838d" body="The URL to be used for obtaining refresh tokens. This MUST be in the form of a URL. The OAuth2 standard requires the use of TLS." annotatedElement="870bda1d-e9ad-483d-9bd7-be0348fb08a7"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
    </packagedElement>
