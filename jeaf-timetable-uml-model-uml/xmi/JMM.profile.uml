    <packagedElement xmi:type="uml:Stereotype" xmi:id="896b1f24-7338-49ca-b852-dc24218373ea" name="JEAFStereotype">
      <ownedComment xmi:id="7bb873cf-ec07-4faf-a063-599e6fc007fb" body="" annotatedElement="896b1f24-7338-49ca-b852-dc24218373ea"/>
      <ownedAttribute xmi:id="d82358ce-63a9-4750-801a-8bc933b883e2" name="base_Stereotype" visibility="private" association="770a1212-77c2-465f-b95e-8535c9751920">
