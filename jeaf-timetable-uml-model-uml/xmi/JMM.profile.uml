      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="5ba55029-ba38-4f2a-8271-78eb29d93193" name="extension_Interceptor" visibility="private" type="9ea1bfcb-807f-43ba-986d-6ada2f341135" aggregation="composite" association="950d205d-9463-4399-a92d-920e2945ace0">
