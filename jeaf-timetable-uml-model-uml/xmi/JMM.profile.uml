      <ownedComment xmi:id="5be9369e-d5bd-4db5-970f-284de561f698" body="Stereotype `«Identifiable»` can be used to mark a class to have an ID." annotatedElement="2a65e533-e071-4529-bd2d-0908be50399d"/>
