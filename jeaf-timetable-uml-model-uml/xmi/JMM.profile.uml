    <packagedElement xmi:type="uml:Stereotype" xmi:id="eb916894-d1c5-400f-a229-1cd8d41c002a" name="Internal">
      <ownedComment xmi:id="95ecf52b-8c86-43e2-aefe-12e5db31d465" body="Stereotype `«Internal»` can be used to mark attributes or roles as internal. This means that in the generated Java code they will be generated as any other property but access methods will only have package visibility." annotatedElement="eb916894-d1c5-400f-a229-1cd8d41c002a"/>
