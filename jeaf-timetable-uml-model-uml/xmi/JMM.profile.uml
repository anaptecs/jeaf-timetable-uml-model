        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="03a8c87c-8fd1-46ce-9d1e-0f3d10eac8e5" name=""/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="24a5e83d-a243-4c3b-ae09-c8ad962ce157" name="DefaultLiteral">
      <ownedComment xmi:id="2fff1da8-0541-41f4-af1f-d98b297bff3d" body="Stereotype `«DefaultLiteral»` can be used to define which literal of an enumeration is the default one if none is provided. &#xA;&#xA;Please be aware default literals only exist in OpenAPI. There is no real equivalent in Java for that." annotatedElement="24a5e83d-a243-4c3b-ae09-c8ad962ce157"/>
      <ownedAttribute xmi:id="e3893cf5-483f-4881-b9bc-6f8bf3d912ac" name="base_EnumerationLiteral" visibility="private" association="b3d3e640-c81f-417c-8bf3-3b71990c8e94">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#EnumerationLiteral"/>
      </ownedAttribute>
    </packagedElement>
