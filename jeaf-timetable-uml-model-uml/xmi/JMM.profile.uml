    <packagedElement xmi:type="uml:Stereotype" xmi:id="4fbdb9ba-7d61-4d88-b6eb-2f38f88d0cb5" name="ValidationGroup">
      <ownedComment xmi:id="83760cec-3e40-4b10-b257-81f3ac68c298" body="The stereotype `«ValidationGroup»` is used to define validation groups. These groups allow validations to be organized and applied selectively in specific contexts.&#xA;&#xA;A typical use case for validation groups is performing validations that are specific to certain API versions." annotatedElement="4fbdb9ba-7d61-4d88-b6eb-2f38f88d0cb5"/>
      <ownedAttribute xmi:id="12f5ca97-e186-4bca-868b-c030bc1ec92a" name="identifier" visibility="private">
        <ownedComment xmi:id="fe87f5a0-b9fb-48aa-a9a6-70f8a462d8ed" body="Identifier for the validation group. The identifier can have any arbitrary value. The only constraint is that it must be unique within the model." annotatedElement="12f5ca97-e186-4bca-868b-c030bc1ec92a"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="a46a2bbc-a7b2-4941-bf06-5d43ce467f92" name="javaDefaultValidationGroup" visibility="private">
        <ownedComment xmi:id="55858f0d-38cc-4a7f-85c8-ee97277fd30e" body="If the tagged value is set to `true`, the group will be used as the default validation group in the generated Java code (Jakarta Validation).&#xA;&#xA;**Notes:**&#xA;&#xA;- Defining a default validation group is optional. If none is defined, constraints without an explicit validation group use the Jakarta Validation standard default group.&#xA;&#xA;- Multiple Java default validation groups may be defined.&#xA;&#xA;- If at least one Java default validation group is defined in the model, the Jakarta Validation standard default group will not be used." annotatedElement="a46a2bbc-a7b2-4941-bf06-5d43ce467f92"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="da337898-1d66-451a-b0a4-e321a4013e6e" name=""/>
      </ownedAttribute>
      <ownedAttribute xmi:id="f307fb6f-94f8-4d4d-900a-702df5013292" name="openAPIValidationGroup" visibility="private">
        <ownedComment xmi:id="7148f424-201a-43d6-b7dc-9347207c7790" body="In Java, multiple validation groups can be used in parallel. OpenAPI does not support this capability. Therefore, when validation groups are used, a specific validation group must be designated for OpenAPI.&#xA;&#xA;During OpenAPI specification generation, only the general constraints and the constraints defined in the OpenAPI validation group are taken into account.&#xA;&#xA;Only one validation group might have this tag set to `true`." annotatedElement="f307fb6f-94f8-4d4d-900a-702df5013292"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="e3a4dad9-e304-43b7-9a1c-2a6cddaf9fed" name=""/>
