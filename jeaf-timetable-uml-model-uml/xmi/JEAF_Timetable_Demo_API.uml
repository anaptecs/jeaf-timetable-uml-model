              <packagedElement xmi:type="uml:Class" xmi:id="2423ef81-73ae-48e3-b748-afe8eede918c" name="ErrorResponse" clientDependency="4e452c63-8cd3-4106-8d2b-e694865e774a">
                <ownedComment xmi:id="fdd95ef8-9f39-454c-9dbf-e09bf9ced855" body="Generic error response that is used to indicate technical problems. Returned data structure is compliant with Problem JSON." annotatedElement="2423ef81-73ae-48e3-b748-afe8eede918c"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Class" xmi:id="05fa8d60-7cf1-420d-8850-d03967c50b03" name="Problem">
                <ownedComment xmi:id="fcd8898e-4f95-4dec-9439-1549c2f1517c" body="Data structure represents a technical problem that occurred during a REST call (aka as Problem JSON). It is compatible with problem structure as it is defined in RFC7807 (https://datatracker.ietf.org/doc/html/rfc7807).&#xA;&#xA;Here, problems are only used to indicate technical problems. Business problems need to provide way more context and thus will be part of response data structure.&#xA;" annotatedElement="05fa8d60-7cf1-420d-8850-d03967c50b03"/>
                <ownedAttribute xmi:id="e9f98f61-fdf3-45ae-b450-e44f4496ecac" name="title" visibility="private" isReadOnly="true">
                  <ownedComment xmi:id="c911ebde-47c1-46a9-bf7a-b9705b4357e0" body="A short, human-readable summary of the problem type. It SHOULD NOT change from occurrence to occurrence of the problem, except for purposes of localization.&#xA;Consumers MUST use the &quot;type&quot; string as the primary identifier for the problem type; the &quot;title&quot; string is advisory and included only for users who are not aware of the semantics of the URI and do not have the ability to discover them." annotatedElement="e9f98f61-fdf3-45ae-b450-e44f4496ecac"/>
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
                </ownedAttribute>
                <ownedAttribute xmi:id="51c2bdc7-3f75-4351-882d-bdb547864ac0" name="status" isReadOnly="true">
                  <ownedComment xmi:id="191667c5-6ece-4b8a-80cc-dfded3e1cecf" body="The HTTP status code ([RFC7231], Section 6) generated by the origin server for this occurrence of the problem." annotatedElement="51c2bdc7-3f75-4351-882d-bdb547864ac0"/>
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/JavaPrimitiveTypes.library.uml#int"/>
                </ownedAttribute>
                <ownedAttribute xmi:id="686731f0-5ed0-449e-a093-04791cac388c" name="type" visibility="private" isReadOnly="true">
                  <ownedComment xmi:id="44cbb83c-d1dd-4567-82e8-0e013cc3e36a" body="A URI reference [RFC3986] that identifies the problem type. When this member is not present, its value is assumed to be &quot;about:blank&quot;." annotatedElement="686731f0-5ed0-449e-a093-04791cac388c"/>
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
                  <defaultValue xmi:type="uml:LiteralString" xmi:id="606dfbff-a055-4002-a92a-748aae0d8028" name="" value="&quot;about:blank&quot;"/>
                </ownedAttribute>
                <ownedAttribute xmi:id="2954a42c-7c41-4163-afe9-59d4ca3cdd00" name="detail" visibility="private" isReadOnly="true">
                  <ownedComment xmi:id="c260d3ba-1c23-47bf-a1ce-418be6f55fb8" body="A human-readable explanation specific to this occurrence of the problem." annotatedElement="2954a42c-7c41-4163-afe9-59d4ca3cdd00"/>
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
                </ownedAttribute>
                <ownedAttribute xmi:id="e25bf8db-21b8-4e4a-96e4-a5398f40d195" name="instance" visibility="private" isReadOnly="true">
                  <ownedComment xmi:id="68e006d8-afb3-4485-b39d-1d02c572b39a" body="A URI reference that identifies the specific occurrence of the problem.  It may or may not yield further information if dereferenced." annotatedElement="e25bf8db-21b8-4e4a-96e4-a5398f40d195"/>
                  <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
                </ownedAttribute>
              </packagedElement>
